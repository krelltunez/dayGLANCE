DayGlance/Info.plist
DayGlanceWidget/Info.plist
ShareExtension/Info.plist

# Xcode build artefacts
DerivedData/
build/
*.xcuserstate
xcuserdata/

# Web assets — generated by: npm run build:ios
DayGlance/Resources/web/
