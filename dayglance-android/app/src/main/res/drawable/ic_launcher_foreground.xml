<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: icon tinted white, inset to keep artwork
     within Android's 72dp safe zone (108dp canvas). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp">
        <bitmap
            android:src="@drawable/ic_launcher_fg"
            android:gravity="fill"
            android:tint="#FFFFFF" />
    </item>
</layer-list>
