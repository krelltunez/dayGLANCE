# Copy this file to keystore.properties (gitignored) and fill in your values.
#
# To generate a keystore (one-time):
#   keytool -genkey -v -keystore dayglance.keystore \
#     -alias dayglance -keyalg RSA -keysize 2048 -validity 10000
#
# Store dayglance.keystore somewhere safe outside the repo, or in the
# dayglance-android/ directory (also gitignored via *.keystore).

storeFile=../dayglance-android/dayglance.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=dayglance
keyPassword=YOUR_KEY_PASSWORD
